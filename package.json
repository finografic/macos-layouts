{
  "name": "@finografic/macos-layouts",
  "type": "module",
  "version": "0.15.0",
  "description": "Trigger perfect window layouts in macOS",
  "homepage": "https://github.com/finografic/macos-layouts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/finografic/macos-layouts.git"
  },
  "bugs": {
    "url": "https://github.com/finografic/macos-layouts/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "author": {
    "name": "Justin Rankin",
    "email": "justin.blair.rankin@gmail.com",
    "url": "https://github.com/finografic"
  },
  "license": "MIT",
  "keywords": [
    "finografic",
    "macos-layouts",
    "genx:type:cli",
    "cli"
  ],
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "module": "./dist/index.mjs",
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./dist/index.mjs",
    "./cli": "./dist/cli.mjs",
    "./package.json": "./package.json"
  },
  "bin": {
    "layouts": "./dist/cli.mjs"
  },
  "scripts": {
    "---------- DEV_AND_BUILD": "---------------------------------------------",
    "dev": "tsdown --watch",
    "dev:cli": "NODE_ENV=development tsx src/cli.ts --",
    "build": "tsdown",
    "link": "pnpm build && pnpm link --global",
    "unlink": "pnpm unlink --global",
    "·········· LINTING": "···················································",
    "lint": "oxlint -c oxlint.config.ts",
    "lint:fix": "oxlint -c oxlint.config.ts --fix",
    "lint:ci": "oxlint -c oxlint.config.ts --quiet",
    "lint:md": "md-lint",
    "lint:md:fix": "md-lint --fix",
    "·········· FORMATTING": "·················································",
    "format:check": "oxfmt --check",
    "format:fix": "oxfmt",
    "·········· TESTING": "···················································",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "·········· PUBLISH:GITHUB": "············································",
    "release:github:patch": "pnpm run release:check && pnpm version patch && git push --follow-tags",
    "release:github:minor": "pnpm run release:check && pnpm version minor && git push --follow-tags",
    "release:github:major": "pnpm run release:check && pnpm version major && git push --follow-tags",
    "release:check": "pnpm format:check && pnpm lint:fix && pnpm typecheck && pnpm test:run",
    "release:publish": "pnpm publish --registry https://npm.pkg.github.com",
    "·········· REGISTRIES": "················································",
    "view:registry:github": "pnpm view @finografic/macos-layouts --registry=https://npm.pkg.github.com",
    "·········· PACKAGES": "··················································",
    "update:oxc-config": "pnpm update @finografic/oxc-config --latest && pnpm update oxfmt --latest && pnpm update oxlint --latest",
    "upgrade:deps:all": "pnpm update --latest",
    "·········· UTILS": "·····················································",
    "setup:hammerspoon": "bash scripts/install-hammerspoon.sh",
    "tsc:debug": "tsc --pretty --project tsconfig.json",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "prepack": "pnpm build",
    "prepare": "husky"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@standard-schema/spec": "^1.1.0",
    "execa": "^9.6.1",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@finografic/md-lint": "^0.9.6",
    "@finografic/oxc-config": "^2.3.7",
    "@types/node": "^24.0.0",
    "husky": "latest",
    "lint-staged": "^16.2.7",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.22.0",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.32.1",
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "oxfmt --no-error-on-unmatched-pattern",
      "oxlint -c oxlint.config.ts --fix --no-error-on-unmatched-pattern"
    ],
    "*.md": [
      "oxfmt --no-error-on-unmatched-pattern",
      "md-lint --fix"
    ],
    "*.{json,jsonc,yml,yaml,toml}": [
      "oxfmt --no-error-on-unmatched-pattern"
    ]
  }
}
